  "scientific_readout": {
    "diagnostic_question": "Do simple routing component baselines match the all-family runtime evidence gate on target exactness, citation grounding, and fail-closed behavior?",
    "interpretation_rule": "The runtime gate and oracle are sanity baselines. A model prediction path should not advance to tool_query, DPO/RLVR, HF publication, or release tagging until it beats collapse and citationless baselines and is competitive with the runtime gate.",
    "next_decision": "Compare saved model/component outputs against this report. If the model only matches action/status but misses citations or fail-closed routing, keep runtime enforcement in the system and avoid new optimization objectives."
  }
